  "558388148171": [
    {
      "text": "Oi",
      "fromMe": false,
      "timestamp": "2026-01-24T13:59:45.407766"
    },
    {
      "text": "\u00c9 pra dar banho e colocar que roupa?",
      "fromMe": true,
      "timestamp": "2026-01-24T14:01:15.857302"
    },
    {
      "text": "Coloca uma camiseta",
      "fromMe": false,
      "timestamp": "2026-01-24T14:01:49.151902"
    },
    {
      "text": "Daquelas mesmo",
      "fromMe": false,
      "timestamp": "2026-01-24T14:01:54.912516"
    },
    {
      "text": "Eu vou mandar outra roupa",
      "fromMe": false,
      "timestamp": "2026-01-24T14:01:58.662435"
    },
    {
      "text": "Pra tua m\u00e3e vestir",
      "fromMe": false,
      "timestamp": "2026-01-24T14:02:02.218866"
    },
    {
      "text": "Nele",
      "fromMe": false,
      "timestamp": "2026-01-24T14:02:05.430548"
    }
  ],
  "5511998542266": [
    {
      "text": "Pior que t\u00f4 dirigindo mano",
      "fromMe": false,
      "timestamp": "2026-01-24T14:02:11.638112"
    },
    {
      "text": "Nem ouvi teus \u00e1udios ainda",
      "fromMe": false,
      "timestamp": "2026-01-24T14:02:17.122858"
    },
    {
      "text": "De boa mano",
      "fromMe": true,
      "timestamp": "2026-01-24T14:17:57.575511"
    }
  ],
  "558388042944": [
    {
      "text": "T\u00e1 certo hominho",
      "fromMe": false,
      "timestamp": "2026-01-24T14:05:15.028651"
    },
    {
      "text": "T\u00e1 bom hominho esse hor\u00e1rio",
