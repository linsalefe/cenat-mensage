<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WhatsFlow — Premium Messaging Platform</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-void: #050508;
            --bg-deep: #0a0a0f;
            --bg-surface: #111118;
            --bg-elevated: #18181f;
            --bg-glass: rgba(255, 255, 255, 0.03);
            --glass-border: rgba(255, 255, 255, 0.08);
            --accent-primary: #00D26A;
            --accent-glow: rgba(0, 210, 106, 0.4);
            --accent-soft: rgba(0, 210, 106, 0.1);
            --accent-secondary: #00B8D4;
            --text-bright: #FAFAFA;
            --text-primary: #E4E4E7;
            --text-muted: #71717A;
            --text-dim: #52525B;
            --danger: #EF4444;
            --danger-soft: rgba(239, 68, 68, 0.1);
            --warning: #F59E0B;
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 16px;
            --radius-xl: 24px;
            --shadow-glow: 0 0 60px -12px var(--accent-glow);
            --shadow-elevated: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
            --transition-fast: 150ms cubic-bezier(0.4, 0, 0.2, 1);
            --transition-smooth: 300ms cubic-bezier(0.4, 0, 0.2, 1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        html { scroll-behavior: smooth; }
        body {
            font-family: 'Sora', sans-serif;
            background: var(--bg-void);
            color: var(--text-primary);
            min-height: 100vh;
            overflow-x: hidden;
        }

        .bg-ambient {
            position: fixed;
            inset: 0;
            z-index: -1;
            overflow: hidden;
        }
        .bg-ambient::before {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: 
                radial-gradient(ellipse at 20% 20%, rgba(0, 210, 106, 0.08) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 80%, rgba(0, 184, 212, 0.06) 0%, transparent 50%);
            animation: ambientFloat 20s ease-in-out infinite;
        }
        @keyframes ambientFloat {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(2%, 2%) rotate(1deg); }
            66% { transform: translate(-1%, 1%) rotate(-1deg); }
        }

        .grain {
            position: fixed;
            inset: 0;
            z-index: 1000;
            pointer-events: none;
            opacity: 0.02;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
        }

        .app-container {
            max-width: 1600px;
            margin: 0 auto;
            padding: 24px;
            position: relative;
            z-index: 1;
        }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 0 40px;
            animation: fadeSlideDown 0.6s ease-out;
        }
        @keyframes fadeSlideDown {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .brand {
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .brand-icon {
            width: 52px;
            height: 52px;
            background: linear-gradient(135deg, var(--accent-primary) 0%, #00B876 100%);
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            box-shadow: var(--shadow-glow);
            position: relative;
            overflow: hidden;
        }
        .brand-icon::after {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.2) 0%, transparent 50%);
        }
        .brand-text h1 {
            font-size: 1.5rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            background: linear-gradient(135deg, var(--text-bright) 0%, var(--text-muted) 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }
        .brand-text span {
            font-size: 0.7rem;
            font-weight: 500;
            color: var(--accent-primary);
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .header-status {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 16px;
            background: var(--bg-glass);
            border: 1px solid var(--glass-border);
            border-radius: 100px;
            font-size: 0.8rem;
            color: var(--text-muted);
        }
        .status-dot {
            width: 8px;
            height: 8px;
            background: var(--accent-primary);
            border-radius: 50%;
            animation: pulse 2s ease-in-out infinite;
        }
        @keyframes pulse {
            0%, 100% { opacity: 1; transform: scale(1); }
            50% { opacity: 0.5; transform: scale(1.2); }
        }

        .config-panel {
            background: var(--bg-glass);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-xl);
            padding: 24px 28px;
            margin-bottom: 32px;
            animation: fadeSlideUp 0.6s ease-out 0.1s both;
        }
        @keyframes fadeSlideUp {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .config-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        .config-header h2 {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1.5px;
            color: var(--text-muted);
        }
        .config-header::after {
            content: '';
            flex: 1;
            height: 1px;
            background: linear-gradient(90deg, var(--glass-border) 0%, transparent 100%);
        }

        .config-grid {
            display: flex;
            gap: 16px;
            align-items: end;
            flex-wrap: wrap;
        }

        .field {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .field label {
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-dim);
            font-family: 'Space Mono', monospace;
        }
        .field input, .field select {
            background: var(--bg-surface);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-sm);
            padding: 14px 16px;
            color: var(--text-primary);
            font-family: 'Space Mono', monospace;
            font-size: 0.85rem;
            transition: var(--transition-fast);
            outline: none;
        }
        .field input:focus, .field select:focus {
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px var(--accent-soft);
        }

        .field-row {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .field-row input {
            flex: 1;
        }

        .btn {
            font-family: 'Sora', sans-serif;
            font-weight: 600;
            font-size: 0.85rem;
            border: none;
            border-radius: var(--radius-sm);
            padding: 14px 24px;
            cursor: pointer;
            transition: var(--transition-smooth);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            position: relative;
            overflow: hidden;
        }
        .btn::before {
            content: '';
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, transparent 50%);
            opacity: 0;
            transition: var(--transition-fast);
        }
        .btn:hover::before { opacity: 1; }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-primary) 0%, #00B876 100%);
            color: #000;
            box-shadow: 0 4px 20px -4px var(--accent-glow);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px -4px var(--accent-glow);
        }

        .btn-ghost {
            background: var(--bg-glass);
            border: 1px solid var(--glass-border);
            color: var(--text-primary);
        }
        .btn-ghost:hover {
            background: var(--bg-elevated);
            border-color: var(--text-dim);
        }

        .btn-danger {
            background: var(--danger-soft);
            border: 1px solid rgba(239, 68, 68, 0.2);
            color: var(--danger);
        }
        .btn-danger:hover {
            background: var(--danger);
            color: white;
        }

        .btn-sm {
            padding: 10px 16px;
            font-size: 0.8rem;
        }

        .btn-icon {
            width: 42px;
            height: 42px;
            padding: 0;
            border-radius: var(--radius-sm);
            font-size: 1rem;
        }

        .btn-copy {
            background: var(--bg-surface);
            border: 1px solid var(--glass-border);
            color: var(--text-muted);
            padding: 10px 12px;
        }
        .btn-copy:hover {
            border-color: var(--accent-primary);
            color: var(--accent-primary);
        }

        .nav-tabs {
            display: flex;
            gap: 8px;
            margin-bottom: 32px;
            animation: fadeSlideUp 0.6s ease-out 0.2s both;
        }
        .nav-tab {
            padding: 14px 28px;
            border-radius: var(--radius-md);
            cursor: pointer;
            background: transparent;
            border: 1px solid transparent;
            color: var(--text-muted);
            font-weight: 500;
            font-size: 0.9rem;
            transition: var(--transition-smooth);
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .nav-tab:hover {
            background: var(--bg-glass);
            color: var(--text-primary);
        }
        .nav-tab.active {
            background: var(--bg-elevated);
            border-color: var(--glass-border);
            color: var(--text-bright);
            box-shadow: var(--shadow-elevated);
        }

        .tab-content {
            display: none;
            animation: fadeIn 0.4s ease-out;
        }
        .tab-content.active { display: block; }
        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        .actions-row {
            display: flex;
            gap: 12px;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }
        .create-form {
            display: flex;
            gap: 12px;
            flex: 1;
        }
        .create-form input {
            flex: 1;
            min-width: 240px;
            background: var(--bg-surface);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-sm);
            padding: 14px 18px;
            color: var(--text-primary);
            font-family: 'Sora', sans-serif;
            font-size: 0.9rem;
            outline: none;
        }
        .create-form input:focus {
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px var(--accent-soft);
        }

        .instances-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(400px, 1fr));
            gap: 20px;
        }

        .instance-card {
            background: var(--bg-glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-lg);
            overflow: hidden;
            transition: var(--transition-smooth);
            animation: cardAppear 0.5s ease-out both;
        }
        @keyframes cardAppear {
            from { opacity: 0; transform: scale(0.95) translateY(10px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }
        .instance-card:hover {
            border-color: rgba(255, 255, 255, 0.12);
            box-shadow: var(--shadow-elevated);
        }

        .card-main {
            padding: 24px;
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 20px;
        }
        .card-title {
            font-size: 1.15rem;
            font-weight: 600;
            color: var(--text-bright);
            margin-bottom: 4px;
        }
        .card-subtitle {
            font-size: 0.7rem;
            color: var(--text-dim);
            font-family: 'Space Mono', monospace;
        }

        .status-pill {
            padding: 6px 14px;
            border-radius: 100px;
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .status-open {
            background: var(--accent-soft);
            color: var(--accent-primary);
            box-shadow: 0 0 20px -4px var(--accent-glow);
        }
        .status-connecting {
            background: rgba(245, 158, 11, 0.1);
            color: var(--warning);
        }
        .status-close {
            background: var(--danger-soft);
            color: var(--danger);
        }

        .card-tabs {
            display: flex;
            gap: 4px;
            margin-bottom: 20px;
            border-bottom: 1px solid var(--glass-border);
            padding-bottom: 12px;
        }
        .card-tab {
            padding: 8px 16px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            font-size: 0.75rem;
            font-weight: 500;
            color: var(--text-muted);
            transition: var(--transition-fast);
        }
        .card-tab:hover {
            background: var(--bg-surface);
            color: var(--text-primary);
        }
        .card-tab.active {
            background: var(--accent-soft);
            color: var(--accent-primary);
        }

        .card-tab-content {
            display: none;
            min-height: 200px;
        }
        .card-tab-content.active {
            display: block;
        }

        .qr-area {
            background: white;
            border-radius: var(--radius-md);
            padding: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 200px;
        }
        .qr-area img {
            max-width: 100%;
            height: auto;
        }
        .qr-placeholder {
            color: #999;
            text-align: center;
            font-size: 0.85rem;
        }
        .qr-placeholder span {
            display: block;
            font-size: 2rem;
            margin-bottom: 8px;
        }

        .qr-actions {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }
        .qr-actions .btn {
            flex: 1;
        }

        /* Credentials Section */
        .credentials-section {
            margin-bottom: 20px;
        }
        .credentials-section h4 {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin-bottom: 12px;
        }
        .credential-item {
            background: var(--bg-surface);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-sm);
            padding: 12px 14px;
            margin-bottom: 10px;
        }
        .credential-item label {
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-dim);
            display: block;
            margin-bottom: 6px;
        }
        .credential-value {
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .credential-value input {
            flex: 1;
            background: transparent;
            border: none;
            color: var(--text-primary);
            font-family: 'Space Mono', monospace;
            font-size: 0.8rem;
            outline: none;
        }
        .credential-value .btn-copy {
            padding: 6px 10px;
            font-size: 0.75rem;
        }

        .api-url-box {
            background: var(--bg-surface);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-sm);
            padding: 14px;
            margin-bottom: 16px;
        }
        .api-url-box label {
            font-size: 0.65rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--text-dim);
            display: block;
            margin-bottom: 8px;
        }
        .api-url-box code {
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
            color: var(--accent-primary);
            word-break: break-all;
        }

        .env-box {
            background: #0d1117;
            border: 1px solid #30363d;
            border-radius: var(--radius-sm);
            padding: 16px;
            margin-top: 16px;
        }
        .env-box-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }
        .env-box-header span {
            font-size: 0.7rem;
            font-weight: 600;
            color: var(--text-muted);
        }
        .env-box pre {
            font-family: 'Space Mono', monospace;
            font-size: 0.75rem;
            color: #7ee787;
            line-height: 1.6;
            margin: 0;
            white-space: pre-wrap;
            word-break: break-all;
        }

        /* Webhook Config */
        .webhook-section h4 {
            font-size: 0.7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-muted);
            margin-bottom: 12px;
        }
        .webhook-form .field {
            margin-bottom: 14px;
        }
        .webhook-form .field input {
            width: 100%;
        }
        .webhook-form .field select {
            width: 100%;
        }

        .events-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
        }
        .event-check {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px 12px;
            background: var(--bg-surface);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: var(--transition-fast);
        }
        .event-check:hover {
            border-color: var(--accent-primary);
        }
        .event-check input[type="checkbox"] {
            appearance: none;
            width: 18px;
            height: 18px;
            background: var(--bg-elevated);
            border: 1px solid var(--glass-border);
            border-radius: 4px;
            cursor: pointer;
            position: relative;
        }
        .event-check input[type="checkbox"]:checked {
            background: var(--accent-primary);
            border-color: var(--accent-primary);
        }
        .event-check input[type="checkbox"]:checked::after {
            content: '✓';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: #000;
            font-size: 12px;
            font-weight: bold;
        }
        .event-check span {
            font-size: 0.75rem;
            color: var(--text-primary);
        }

        .webhook-actions {
            display: flex;
            gap: 10px;
            margin-top: 16px;
        }
        .webhook-status {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 16px;
            background: var(--bg-surface);
            border-radius: var(--radius-sm);
            margin-top: 12px;
        }
        .webhook-status.active {
            background: var(--accent-soft);
        }
        .webhook-status.inactive {
            background: var(--danger-soft);
        }
        .webhook-status span {
            font-size: 0.8rem;
        }

        .card-footer {
            padding: 16px 24px;
            background: var(--bg-surface);
            border-top: 1px solid var(--glass-border);
            display: flex;
            justify-content: flex-end;
        }

        /* Chat Layout */
        .chat-layout {
            display: grid;
            grid-template-columns: 340px 1fr;
            gap: 20px;
            height: calc(100vh - 280px);
            min-height: 600px;
        }

        .sidebar {
            background: var(--bg-glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-lg);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .sidebar-header {
            padding: 20px;
            border-bottom: 1px solid var(--glass-border);
        }
        .sidebar-header h3 {
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 14px;
            color: var(--text-bright);
        }
        .sidebar-header select {
            width: 100%;
            background: var(--bg-surface);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-sm);
            padding: 12px 14px;
            color: var(--text-primary);
            font-family: 'Sora', sans-serif;
            font-size: 0.85rem;
            outline: none;
            cursor: pointer;
        }

        .refresh-toggle {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-top: 12px;
            font-size: 0.75rem;
            color: var(--text-muted);
        }
        .refresh-toggle input[type="checkbox"] {
            appearance: none;
            width: 36px;
            height: 20px;
            background: var(--bg-surface);
            border-radius: 100px;
            position: relative;
            cursor: pointer;
        }
        .refresh-toggle input[type="checkbox"]::after {
            content: '';
            position: absolute;
            top: 3px;
            left: 3px;
            width: 14px;
            height: 14px;
            background: var(--text-muted);
            border-radius: 50%;
            transition: var(--transition-fast);
        }
        .refresh-toggle input[type="checkbox"]:checked {
            background: var(--accent-primary);
        }
        .refresh-toggle input[type="checkbox"]:checked::after {
            transform: translateX(16px);
            background: white;
        }

        .contacts-list {
            flex: 1;
            overflow-y: auto;
            padding: 12px;
        }
        .contacts-list::-webkit-scrollbar {
            width: 6px;
        }
        .contacts-list::-webkit-scrollbar-thumb {
            background: var(--glass-border);
            border-radius: 3px;
        }

        .contact {
            padding: 14px 16px;
            border-radius: var(--radius-md);
            cursor: pointer;
            margin-bottom: 6px;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: var(--transition-fast);
            border: 1px solid transparent;
        }
        .contact:hover {
            background: var(--bg-elevated);
        }
        .contact.active {
            background: linear-gradient(135deg, var(--accent-primary) 0%, #00B876 100%);
            box-shadow: 0 4px 20px -4px var(--accent-glow);
        }
        .contact.active * {
            color: #000 !important;
        }

        .contact-avatar {
            width: 46px;
            height: 46px;
            border-radius: 50%;
            background: var(--bg-surface);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            flex-shrink: 0;
        }
        .contact.active .contact-avatar {
            background: rgba(0, 0, 0, 0.2);
        }

        .contact-info {
            flex: 1;
            overflow: hidden;
        }
        .contact-name {
            font-weight: 600;
            font-size: 0.9rem;
            color: var(--text-bright);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .contact-number {
            font-size: 0.7rem;
            color: var(--text-dim);
            font-family: 'Space Mono', monospace;
            margin-top: 2px;
        }
        .contact-preview {
            font-size: 0.75rem;
            color: var(--text-muted);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
            margin-top: 4px;
        }

        .sidebar-footer {
            padding: 12px;
            border-top: 1px solid var(--glass-border);
        }
        .sidebar-footer .btn {
            width: 100%;
        }

        .chat-main {
            background: var(--bg-glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-lg);
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }

        .chat-header {
            padding: 18px 24px;
            border-bottom: 1px solid var(--glass-border);
            display: flex;
            align-items: center;
            gap: 16px;
        }
        .chat-avatar {
            width: 48px;
            height: 48px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent-primary) 0%, #00B876 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.4rem;
        }
        .chat-info h3 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-bright);
        }
        .chat-info p {
            font-size: 0.75rem;
            color: var(--text-muted);
            font-family: 'Space Mono', monospace;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 24px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .chat-messages::-webkit-scrollbar {
            width: 6px;
        }
        .chat-messages::-webkit-scrollbar-thumb {
            background: var(--glass-border);
            border-radius: 3px;
        }

        .message {
            max-width: 65%;
            padding: 14px 18px;
            border-radius: var(--radius-md);
            font-size: 0.9rem;
            line-height: 1.5;
            animation: messageAppear 0.3s ease-out;
        }
        @keyframes messageAppear {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .message.sent {
            align-self: flex-end;
            background: linear-gradient(135deg, var(--accent-primary) 0%, #00B876 100%);
            color: #000;
            border-bottom-right-radius: 4px;
        }
        .message.received {
            align-self: flex-start;
            background: var(--bg-elevated);
            border: 1px solid var(--glass-border);
            border-bottom-left-radius: 4px;
        }
        .message-time {
            font-size: 0.6rem;
            opacity: 0.7;
            margin-top: 6px;
            text-align: right;
            font-family: 'Space Mono', monospace;
        }

        .chat-input {
            padding: 18px 24px;
            border-top: 1px solid var(--glass-border);
            display: flex;
            gap: 14px;
        }
        .chat-input input {
            flex: 1;
            background: var(--bg-surface);
            border: 1px solid var(--glass-border);
            border-radius: 100px;
            padding: 16px 24px;
            color: var(--text-primary);
            font-family: 'Sora', sans-serif;
            font-size: 0.9rem;
            outline: none;
        }
        .chat-input input:focus {
            border-color: var(--accent-primary);
            box-shadow: 0 0 0 3px var(--accent-soft);
        }
        .chat-input .btn {
            width: 52px;
            height: 52px;
            border-radius: 50%;
            padding: 0;
            font-size: 1.2rem;
        }

        .chat-empty {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            text-align: center;
        }
        .chat-empty-content span {
            font-size: 4rem;
            display: block;
            margin-bottom: 16px;
            opacity: 0.5;
        }
        .chat-empty-content p {
            color: var(--text-muted);
        }

        .modal-overlay {
            position: fixed;
            inset: 0;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 100;
        }
        .modal-overlay.show { display: flex; }

        .modal {
            background: var(--bg-elevated);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-xl);
            padding: 32px;
            width: 420px;
            max-width: 90%;
            animation: modalAppear 0.3s ease-out;
        }
        @keyframes modalAppear {
            from { opacity: 0; transform: scale(0.95) translateY(20px); }
            to { opacity: 1; transform: scale(1) translateY(0); }
        }
        .modal h3 {
            font-size: 1.2rem;
            font-weight: 600;
            margin-bottom: 24px;
            color: var(--text-bright);
        }
        .modal .field {
            margin-bottom: 20px;
        }
        .modal .field input {
            width: 100%;
        }
        .modal-actions {
            display: flex;
            gap: 12px;
            justify-content: flex-end;
            margin-top: 28px;
        }

        .toast {
            position: fixed;
            bottom: 32px;
            right: 32px;
            background: var(--bg-elevated);
            border: 1px solid var(--glass-border);
            border-radius: var(--radius-md);
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            transform: translateY(100px);
            opacity: 0;
            transition: var(--transition-smooth);
            z-index: 200;
            box-shadow: var(--shadow-elevated);
        }
        .toast.show {
            transform: translateY(0);
            opacity: 1;
        }
        .toast.success { border-color: var(--accent-primary); }
        .toast.error { border-color: var(--danger); }

        .spinner {
            width: 20px;
            height: 20px;
            border: 2px solid transparent;
            border-top-color: currentColor;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        @media (max-width: 900px) {
            .instances-grid {
                grid-template-columns: 1fr;
            }
            .chat-layout {
                grid-template-columns: 1fr;
                height: auto;
            }
            .sidebar {
                height: 350px;
            }
            .chat-main {
                height: 500px;
            }
        }
    </style>
</head>
<body>
    <div class="bg-ambient"></div>
    <div class="grain"></div>

    <div class="app-container">
        <header class="header">
            <div class="brand">
                <div class="brand-icon">⚡</div>
                <div class="brand-text">
                    <h1>WhatsFlow</h1>
                    <span>Premium Messaging</span>
                </div>
            </div>
            <div class="header-status">
                <div class="status-dot"></div>
                <span>Sistema Operacional</span>
            </div>
        </header>

        <section class="config-panel">
            <div class="config-header">
                <h2>🔧 Configurações de Conexão</h2>
            </div>
            <div class="config-grid">
                <div class="field">
                    <label>Server URL</label>
                    <input type="text" id="serverUrl" value="https://api.whatsflow.cloud" style="width:220px">
                </div>
                <div class="field">
                    <label>Webhook URL</label>
                    <input type="text" id="webhookUrl" value="https://whatsflow.cloud/webhook" style="width:220px">
                </div>
                <div class="field">
                    <label>API Key Global</label>
                    <input type="password" id="apiKey" value="minha-chave-secreta-123" style="width:180px">
                </div>
                <button class="btn btn-primary" onclick="loadInstances()">Conectar</button>
            </div>
        </section>

        <nav class="nav-tabs">
            <div class="nav-tab active" onclick="switchTab('instances')">
                <span>📱</span>
                <span>Instâncias</span>
            </div>
            <div class="nav-tab" onclick="switchTab('chat')">
                <span>💬</span>
                <span>Conversas</span>
            </div>
        </nav>

        <div id="tab-instances" class="tab-content active">
            <div class="actions-row">
                <div class="create-form">
                    <input type="text" id="newInstanceName" placeholder="Nome da nova instância...">
                    <button class="btn btn-primary" onclick="createInstance()">+ Nova Instância</button>
                </div>
                <button class="btn btn-ghost" onclick="loadInstances()">🔄 Atualizar</button>
            </div>
            <div id="instancesContainer" class="instances-grid"></div>
        </div>

        <div id="tab-chat" class="tab-content">
            <div class="chat-layout">
                <div class="sidebar">
                    <div class="sidebar-header">
                        <h3>Conversas</h3>
                        <select id="chatInstance" onchange="loadContacts()"></select>
                        <div class="refresh-toggle">
                            <input type="checkbox" id="autoRefresh" checked>
                            <label for="autoRefresh">Atualização automática</label>
                        </div>
                    </div>
                    <div class="contacts-list" id="contactsList"></div>
                    <div class="sidebar-footer">
                        <button class="btn btn-primary" onclick="openNewChatModal()">+ Nova Conversa</button>
                    </div>
                </div>
                <div class="chat-main" id="chatMain">
                    <div class="chat-empty">
                        <div class="chat-empty-content">
                            <span>💬</span>
                            <p>Selecione uma conversa para começar</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="newChatModal">
        <div class="modal">
            <h3>Nova Conversa</h3>
            <div class="field">
                <label>Número com DDI</label>
                <input type="text" id="newChatNumber" placeholder="5511999999999">
            </div>
            <div class="modal-actions">
                <button class="btn btn-ghost" onclick="closeNewChatModal()">Cancelar</button>
                <button class="btn btn-primary" onclick="startNewChat()">Iniciar</button>
            </div>
        </div>
    </div>

    <div id="toast" class="toast">
        <span id="toastMessage"></span>
    </div>

    <script>
        // Verificar autenticação
        if (sessionStorage.getItem("whatsflow_authenticated") !== "true") {
            window.location.href = "login.html";
        }
        let currentChat = null;
        let conversations = {};
        let refreshInterval = null;
        let instancesData = [];

        const getConfig = () => ({
            serverUrl: document.getElementById('serverUrl').value.replace(/\/$/, ''),
            webhookUrl: document.getElementById('webhookUrl').value.replace(/\/$/, ''),
            apiKey: document.getElementById('apiKey').value
        });

        const showToast = (message, type = 'success') => {
            const toast = document.getElementById('toast');
            document.getElementById('toastMessage').textContent = message;
            toast.className = `toast ${type} show`;
            setTimeout(() => toast.classList.remove('show'), 3000);
        };

        const copyToClipboard = (text) => {
            navigator.clipboard.writeText(text);
            showToast('Copiado!');
        };

        const apiCall = async (endpoint, method = 'GET', body = null) => {
            const { serverUrl, apiKey } = getConfig();
            const options = { method, headers: { 'apikey': apiKey, 'Content-Type': 'application/json' } };
            if (body) options.body = JSON.stringify(body);
            const response = await fetch(`${serverUrl}${endpoint}`, options);
            return response.json();
        };

        const switchTab = (tab) => {
            document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.tab-content').forEach(t => t.classList.remove('active'));
            document.querySelector(`.nav-tab:nth-child(${tab === 'instances' ? 1 : 2})`).classList.add('active');
            document.getElementById(`tab-${tab}`).classList.add('active');
            if (tab === 'chat') {
                updateChatInstanceSelect();
                loadConversations();
                startAutoRefresh();
            } else {
                stopAutoRefresh();
            }
        };

        const switchCardTab = (instanceName, tabName) => {
            const card = document.getElementById(`card-${instanceName}`);
            card.querySelectorAll('.card-tab').forEach(t => t.classList.remove('active'));
            card.querySelectorAll('.card-tab-content').forEach(t => t.classList.remove('active'));
            card.querySelector(`.card-tab[data-tab="${tabName}"]`).classList.add('active');
            card.querySelector(`.card-tab-content[data-content="${tabName}"]`).classList.add('active');
        };

        const startAutoRefresh = () => {
            stopAutoRefresh();
            refreshInterval = setInterval(() => {
                if (document.getElementById('autoRefresh').checked) {
                    loadConversations();
                }
            }, 3000);
        };

        const stopAutoRefresh = () => {
            if (refreshInterval) {
                clearInterval(refreshInterval);
                refreshInterval = null;
            }
        };

        const loadInstances = async () => {
            try {
                const data = await apiCall('/instance/fetchInstances');
                instancesData = data;
                renderInstances(data);
                showToast(`${data.length} instância(s) encontrada(s)`);
            } catch (error) { showToast('Erro ao conectar na API', 'error'); }
        };

        const updateChatInstanceSelect = () => {
            const select = document.getElementById('chatInstance');
            let options = '';
            instancesData.forEach(inst => {
                if (inst.connectionStatus === 'open') {
                    options += `<option value="${inst.name}">${inst.name}</option>`;
                }
            });
            select.innerHTML = options || '<option value="">Nenhuma conectada</option>';
        };

        const generateToken = () => {
            return 'xxxx-xxxx-xxxx-xxxx'.replace(/x/g, () => Math.random().toString(36)[2]);
        };

        const renderInstances = (instances) => {
            const container = document.getElementById('instancesContainer');
            const { serverUrl, apiKey } = getConfig();
            
            if (!instances || instances.length === 0) {
                container.innerHTML = `<div style="grid-column:1/-1;text-align:center;padding:60px;color:var(--text-muted)"><p style="font-size:3rem;margin-bottom:16px">📱</p><p>Nenhuma instância encontrada.<br>Crie uma nova para começar.</p></div>`;
                return;
            }
            
            container.innerHTML = instances.map((instance, i) => {
                const instanceToken = instance.token || generateToken();
                const sendTextUrl = `${serverUrl}/message/sendText/${instance.name}`;
                
                return `
                <div class="instance-card" id="card-${instance.name}" style="animation-delay:${i * 0.1}s">
                    <div class="card-main">
                        <div class="card-header">
                            <div>
                                <div class="card-title">${instance.name}</div>
                                <div class="card-subtitle">Criado em ${new Date().toLocaleDateString('pt-BR')}</div>
                            </div>
                            <span class="status-pill status-${instance.connectionStatus || 'close'}">${instance.connectionStatus === 'open' ? 'Conectado' : instance.connectionStatus || 'Desconectado'}</span>
                        </div>

                        <div class="card-tabs">
                            <div class="card-tab active" data-tab="connection" onclick="switchCardTab('${instance.name}', 'connection')">📱 Conexão</div>
                            <div class="card-tab" data-tab="credentials" onclick="switchCardTab('${instance.name}', 'credentials')">🔑 Credenciais</div>
                            <div class="card-tab" data-tab="webhook" onclick="switchCardTab('${instance.name}', 'webhook')">🔗 Webhook</div>
                        </div>

                        <!-- Connection Tab -->
                        <div class="card-tab-content active" data-content="connection">
                            <div class="qr-area" id="qr-${instance.name}">
                                ${instance.connectionStatus === 'open' 
                                    ? '<div class="qr-placeholder"><span>✅</span>Instância conectada</div>'
                                    : '<div class="qr-placeholder"><span>📷</span>Clique em "Gerar QR" para conectar</div>'}
                            </div>
                            <div class="qr-actions">
                                <button class="btn btn-primary btn-sm" onclick="generateQR('${instance.name}')">📷 Gerar QR</button>
                                <button class="btn btn-ghost btn-sm" onclick="checkStatus('${instance.name}')">🔍 Status</button>
                            </div>
                        </div>

                        <!-- Credentials Tab -->
                        <div class="card-tab-content" data-content="credentials">
                            <div class="credentials-section">
                                <h4>Dados da Instância</h4>
                                
                                <div class="credential-item">
                                    <label>Nome da Instância</label>
                                    <div class="credential-value">
                                        <input type="text" value="${instance.name}" readonly>
                                        <button class="btn btn-copy btn-sm" onclick="copyToClipboard('${instance.name}')">📋</button>
                                    </div>
                                </div>

                                <div class="credential-item">
                                    <label>ID da Instância</label>
                                    <div class="credential-value">
                                        <input type="text" value="${instance.id || 'N/A'}" readonly>
                                        <button class="btn btn-copy btn-sm" onclick="copyToClipboard('${instance.id || ''}')">📋</button>
                                    </div>
                                </div>

                                <div class="credential-item">
                                    <label>API Key</label>
                                    <div class="credential-value">
                                        <input type="password" value="${apiKey}" readonly id="apikey-${instance.name}">
                                        <button class="btn btn-copy btn-sm" onclick="copyToClipboard('${apiKey}')">📋</button>
                                    </div>
                                </div>
                            </div>

                            <div class="api-url-box">
                                <label>URL para Enviar Mensagens</label>
                                <code>${sendTextUrl}</code>
                            </div>

                            <div class="env-box">
                                <div class="env-box-header">
                                    <span>📄 .env para seu Agente</span>
                                    <button class="btn btn-copy btn-sm" onclick="copyEnv('${instance.name}', '${instance.id || ''}', '${apiKey}', '${serverUrl}')">📋 Copiar</button>
                                </div>
                                <pre>INSTANCE_NAME=${instance.name}
INSTANCE_ID=${instance.id || 'N/A'}
API_KEY=${apiKey}
API_URL=${serverUrl}
SEND_TEXT_URL=${sendTextUrl}</pre>
                            </div>
                        </div>

                        <!-- Webhook Tab -->
                        <div class="card-tab-content" data-content="webhook">
                            <div class="webhook-section">
                                <h4>Configurar Webhook do Agente</h4>
                                
                                <div class="webhook-form">
                                    <div class="field">
                                        <label>URL do Webhook (seu agente FastAPI)</label>
                                        <input type="text" id="webhook-url-${instance.name}" placeholder="https://seu-agente.com/webhook">
                                    </div>

                                    <div class="field">
                                        <label>Eventos</label>
                                        <div class="events-grid">
                                            <label class="event-check">
                                                <input type="checkbox" id="evt-messages-${instance.name}" checked>
                                                <span>Mensagens</span>
                                            </label>
                                            <label class="event-check">
                                                <input type="checkbox" id="evt-status-${instance.name}">
                                                <span>Status</span>
                                            </label>
                                            <label class="event-check">
                                                <input type="checkbox" id="evt-contacts-${instance.name}">
                                                <span>Contatos</span>
                                            </label>
                                            <label class="event-check">
                                                <input type="checkbox" id="evt-chats-${instance.name}">
                                                <span>Chats</span>
                                            </label>
                                        </div>
                                    </div>

                                    <div class="webhook-actions">
                                        <button class="btn btn-primary btn-sm" onclick="saveWebhook('${instance.name}')">💾 Salvar Webhook</button>
                                        <button class="btn btn-ghost btn-sm" onclick="testWebhook('${instance.name}')">🧪 Testar</button>
                                        <button class="btn btn-ghost btn-sm" onclick="loadWebhook('${instance.name}')">🔄 Carregar</button>
                                    </div>

                                    <div class="webhook-status inactive" id="webhook-status-${instance.name}">
                                        <span>⚪ Webhook não configurado</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="card-footer">
                        <button class="btn btn-danger btn-sm" onclick="deleteInstance('${instance.name}')">🗑️ Excluir Instância</button>
                    </div>
                </div>
            `}).join('');
            
            // Load webhook status for each instance
            instances.forEach(inst => {
                loadWebhook(inst.name);
            });
            
            updateChatInstanceSelect();
        };

        const copyEnv = (name, id, apiKey, serverUrl) => {
            const env = `INSTANCE_NAME=${name}
INSTANCE_ID=${id}
API_KEY=${apiKey}
API_URL=${serverUrl}
SEND_TEXT_URL=${serverUrl}/message/sendText/${name}`;
            copyToClipboard(env);
        };

        const createInstance = async () => {
            const nameInput = document.getElementById('newInstanceName');
            const name = nameInput.value.trim();
            if (!name) { showToast('Digite um nome', 'error'); return; }
            try {
                await apiCall('/instance/create', 'POST', { instanceName: name, integration: 'WHATSAPP-BAILEYS', qrcode: true });
                showToast(`Instância "${name}" criada!`);
                nameInput.value = '';
                setTimeout(loadInstances, 500);
            } catch (error) { showToast('Erro ao criar', 'error'); }
        };

        const generateQR = async (instanceName) => {
            const qrContainer = document.getElementById(`qr-${instanceName}`);
            qrContainer.innerHTML = '<div class="spinner" style="border-top-color:#000"></div>';
            try {
                const data = await apiCall(`/instance/connect/${instanceName}`);
                if (data.base64) {
                    qrContainer.innerHTML = `<img src="${data.base64}" alt="QR Code">`;
                    showToast('QR Code gerado!');
                } else {
                    qrContainer.innerHTML = `<div class="qr-placeholder"><span>✅</span>Já conectado</div>`;
                }
            } catch (error) { 
                qrContainer.innerHTML = '<div class="qr-placeholder"><span>❌</span>Erro ao gerar QR</div>'; 
            }
        };

        const checkStatus = async (instanceName) => {
            try {
                const data = await apiCall(`/instance/connectionState/${instanceName}`);
                const state = data.instance?.state || 'unknown';
                const badge = document.querySelector(`#card-${instanceName} .status-pill`);
                if (badge) { 
                    badge.className = `status-pill status-${state}`; 
                    badge.textContent = state === 'open' ? 'Conectado' : state === 'connecting' ? 'Conectando' : 'Desconectado';
                }
                showToast(`Status: ${state}`);
                
                // Update QR area if connected
                if (state === 'open') {
                    const qrContainer = document.getElementById(`qr-${instanceName}`);
                    qrContainer.innerHTML = `<div class="qr-placeholder"><span>✅</span>Instância conectada</div>`;
                }
                
                updateChatInstanceSelect();
            } catch (error) { showToast('Erro ao verificar status', 'error'); }
        };

        const deleteInstance = async (instanceName) => {
            if (!confirm(`Excluir a instância "${instanceName}"?\n\nEssa ação não pode ser desfeita.`)) return;
            try {
                await apiCall(`/instance/delete/${instanceName}`, 'DELETE');
                showToast('Instância excluída!');
                loadInstances();
            } catch (error) { showToast('Erro ao excluir', 'error'); }
        };

        // Webhook functions
        const saveWebhook = async (instanceName) => {
            const url = document.getElementById(`webhook-url-${instanceName}`).value.trim();
            if (!url) { showToast('Digite a URL do webhook', 'error'); return; }

            const events = [];
            if (document.getElementById(`evt-messages-${instanceName}`).checked) events.push('MESSAGES_UPSERT');
            if (document.getElementById(`evt-status-${instanceName}`).checked) events.push('CONNECTION_UPDATE');
            if (document.getElementById(`evt-contacts-${instanceName}`).checked) events.push('CONTACTS_UPSERT');
            if (document.getElementById(`evt-chats-${instanceName}`).checked) events.push('CHATS_UPSERT');

            try {
                await apiCall(`/webhook/set/${instanceName}`, 'POST', {
                    webhook: {
                        enabled: true,
                        url: url,
                        events: events
                    }
                });
                showToast('Webhook salvo com sucesso!');
                updateWebhookStatus(instanceName, true, url);
            } catch (error) { 
                showToast('Erro ao salvar webhook', 'error'); 
            }
        };

        const loadWebhook = async (instanceName) => {
            try {
                const data = await apiCall(`/webhook/find/${instanceName}`);
                if (data && data.url) {
                    document.getElementById(`webhook-url-${instanceName}`).value = data.url;
                    
                    // Check events
                    const events = data.events || [];
                    document.getElementById(`evt-messages-${instanceName}`).checked = events.includes('MESSAGES_UPSERT');
                    document.getElementById(`evt-status-${instanceName}`).checked = events.includes('CONNECTION_UPDATE');
                    document.getElementById(`evt-contacts-${instanceName}`).checked = events.includes('CONTACTS_UPSERT');
                    document.getElementById(`evt-chats-${instanceName}`).checked = events.includes('CHATS_UPSERT');
                    
                    updateWebhookStatus(instanceName, data.enabled, data.url);
                }
            } catch (error) { 
                console.log('Webhook não configurado para', instanceName);
            }
        };

        const testWebhook = async (instanceName) => {
            const url = document.getElementById(`webhook-url-${instanceName}`).value.trim();
            if (!url) { showToast('Configure a URL primeiro', 'error'); return; }
            
            try {
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ event: 'test', instance: instanceName, timestamp: new Date().toISOString() })
                });
                if (response.ok) {
                    showToast('Webhook respondeu com sucesso!');
                } else {
                    showToast('Webhook retornou erro: ' + response.status, 'error');
                }
            } catch (error) {
                showToast('Erro ao testar webhook: ' + error.message, 'error');
            }
        };

        const updateWebhookStatus = (instanceName, enabled, url) => {
            const statusEl = document.getElementById(`webhook-status-${instanceName}`);
            if (enabled && url) {
                statusEl.className = 'webhook-status active';
                statusEl.innerHTML = `<span>🟢 Webhook ativo: ${url.substring(0, 40)}${url.length > 40 ? '...' : ''}</span>`;
            } else {
                statusEl.className = 'webhook-status inactive';
                statusEl.innerHTML = '<span>⚪ Webhook não configurado</span>';
            }
        };

        // Chat functions
        const loadConversations = async () => {
            const { webhookUrl } = getConfig();
            try {
                const response = await fetch(`${webhookUrl}/messages`);
                conversations = await response.json();
                renderContacts();
                if (currentChat) renderChat();
            } catch (error) {
                console.error('Erro ao carregar conversas:', error);
            }
        };

        const renderContacts = () => {
            const container = document.getElementById('contactsList');
            const numbers = Object.keys(conversations);
            
            if (numbers.length === 0) {
                container.innerHTML = '<p style="text-align:center;color:var(--text-muted);padding:40px;font-size:0.85rem">Nenhuma conversa ainda</p>';
                return;
            }

            container.innerHTML = numbers.map(number => {
                const msgs = conversations[number];
                const lastMsg = msgs[msgs.length - 1];
                const isActive = currentChat === number;
                return `
                    <div class="contact ${isActive ? 'active' : ''}" onclick="selectChat('${number}')">
                        <div class="contact-avatar">👤</div>
                        <div class="contact-info">
                            <div class="contact-name">${formatNumber(number)}</div>
                            <div class="contact-number">${number}</div>
                            <div class="contact-preview">${lastMsg?.fromMe ? '✓ ' : ''}${lastMsg?.text?.substring(0, 35) || ''}${lastMsg?.text?.length > 35 ? '...' : ''}</div>
                        </div>
                    </div>
                `;
            }).join('');
        };

        const formatNumber = (number) => {
            if (number.startsWith('55') && number.length >= 12) {
                const ddd = number.substring(2, 4);
                const rest = number.substring(4);
                return `(${ddd}) ${rest.substring(0, 5)}-${rest.substring(5)}`;
            }
            return number;
        };

        const selectChat = (number) => {
            currentChat = number;
            renderContacts();
            renderChat();
        };

        const renderChat = () => {
            const container = document.getElementById('chatMain');
            const messages = conversations[currentChat] || [];
            
            container.innerHTML = `
                <div class="chat-header">
                    <div class="chat-avatar">👤</div>
                    <div class="chat-info">
                        <h3>${formatNumber(currentChat)}</h3>
                        <p>${currentChat}</p>
                    </div>
                </div>
                <div class="chat-messages" id="chatMessages">
                    ${messages.map(m => `
                        <div class="message ${m.fromMe ? 'sent' : 'received'}">
                            ${escapeHtml(m.text)}
                            <div class="message-time">${formatTime(m.timestamp)}</div>
                        </div>
                    `).join('') || '<p style="text-align:center;color:var(--text-muted);margin-top:40px">Nenhuma mensagem</p>'}
                </div>
                <div class="chat-input">
                    <input type="text" id="messageInput" placeholder="Digite sua mensagem..." onkeypress="if(event.key==='Enter')sendMessage()">
                    <button class="btn btn-primary" onclick="sendMessage()">📤</button>
                </div>
            `;
            
            const msgs = document.getElementById('chatMessages');
            msgs.scrollTop = msgs.scrollHeight;
        };

        const escapeHtml = (text) => {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        };

        const formatTime = (timestamp) => {
            const date = new Date(timestamp);
            return date.toLocaleTimeString('pt-BR', { hour: '2-digit', minute: '2-digit' });
        };

        const sendMessage = async () => {
            const input = document.getElementById('messageInput');
            const text = input.value.trim();
            if (!text || !currentChat) return;
            
            const instance = document.getElementById('chatInstance').value;
            if (!instance) { showToast('Selecione uma instância', 'error'); return; }
            
            try {
                await apiCall(`/message/sendText/${instance}`, 'POST', { number: currentChat, text });
                input.value = '';
                showToast('Enviada!');
                setTimeout(loadConversations, 500);
            } catch (error) { showToast('Erro ao enviar', 'error'); }
        };

        const openNewChatModal = () => document.getElementById('newChatModal').classList.add('show');
        const closeNewChatModal = () => document.getElementById('newChatModal').classList.remove('show');

        const startNewChat = () => {
            const number = document.getElementById('newChatNumber').value.replace(/\D/g, '');
            if (!number) { showToast('Digite o número', 'error'); return; }
            currentChat = number;
            if (!conversations[number]) conversations[number] = [];
            closeNewChatModal();
            document.getElementById('newChatNumber').value = '';
            renderContacts();
            renderChat();
        };

        document.addEventListener('DOMContentLoaded', () => {
            setTimeout(loadInstances, 500);
        });
    </script>
</body>
</html>
