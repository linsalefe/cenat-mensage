# Template de configuração — copie para .env e preencha os secrets

# Segurança (gerar com: python3 -c "import secrets; print(secrets.token_urlsafe(64))")
SECRET_KEY=CHANGE_ME

# Banco de dados (schema mensageria no Postgres existente)
DATABASE_URL=postgresql+asyncpg://evolution:CHANGE_ME@127.0.0.1:5432/evolution
DB_SCHEMA=mensageria

# Evolution API (container local)
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=CHANGE_ME

# Webhook inbound (endereço deste backend visto pelo container Evolution)
EDUFLOW_WEBHOOK_URL=http://localhost:3020/api/evolution/webhook

# CORS
CORS_ORIGINS=http://localhost:3000

# Diretório de mídia recebida via webhook
MEDIA_DIR=/home/ubuntu/mensageria/uploads

# Broadcast media (Fase 5.1)
MEDIA_ROOT=/var/lib/mensageria/media
MEDIA_MAX_BYTES=16777216

# Secret opcional para o webhook do Evolution
WEBHOOK_SECRET=

# Servidor
APP_HOST=0.0.0.0
APP_PORT=3020
APP_ENV=development
